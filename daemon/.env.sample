ANTHROPIC_API_KEY=sk-ant-...
AGENT_NUMBER=+1xxxxxxxxxx   # Signal number the agent runs on
USER_NUMBER=+1xxxxxxxxxx    # Your number (who the agent talks to)
SIGNAL_URL=http://127.0.0.1:46871 # signal-cli HTTP daemon URL
ASSISTANT_NAME=Scaffold           # Name of the assistant (used in prompts + startup msg)
USER_NAME=User                    # Your name (used in prompts)
DB_PATH=./scaffold.db             # Optional, this is the default
API_HOST=127.0.0.1                # Bind API to localhost
API_PORT=46873                    # Local API port
API_TOKEN=replace-with-long-random-token
