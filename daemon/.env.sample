ANTHROPIC_API_KEY=sk-ant-...
AGENT_NUMBER=+1xxxxxxxxxx   # Signal number the agent runs on
USER_NUMBER=+1xxxxxxxxxx    # Your number (who the agent talks to)
SIGNAL_URL=http://127.0.0.1:46871 # signal-cli HTTP daemon URL
ASSISTANT_NAME=Scaffold           # Name of the assistant (used in prompts + startup msg)
USER_NAME=User                    # Your name (used in prompts)
DB_PATH=./scaffold.db             # Optional, this is the default
CONFIG_DIR=./config               # YAML config directory (agent, tools, triage, cortex)
API_HOST=127.0.0.1                # Bind API to localhost
API_PORT=46873                    # Local API port
API_TOKEN=replace-with-long-random-token

# Browser auth
APP_USERNAME=replace-with-username
APP_PASSWORD_HASH=replace-with-bcrypt-hash  # See generation instructions below
SESSION_TTL_HOURS=168             # Session lifetime in hours (default: 7 days)
COOKIE_SECURE=true                # Set false for local HTTP dev (default: true)
COOKIE_DOMAIN=                    # Optional: set to your domain in production
LOGIN_RATE_LIMIT_WINDOW_SECS=300  # Rate limit window in seconds (default: 5 min)
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5   # Max failed logins per window (default: 5)

# Generate APP_PASSWORD_HASH with:
#
#   cat >/tmp/mkhash.go <<'EOF'
#   package main
#   import (
#     "fmt"
#     "golang.org/x/crypto/bcrypt"
#   )
#   func main() {
#     h, err := bcrypt.GenerateFromPassword([]byte("replace-with-password"), 14)
#     if err != nil { panic(err) }
#     fmt.Println(string(h))
#   }
#   EOF
#   go run /tmp/mkhash.go
